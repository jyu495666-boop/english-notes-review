# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 飞书应用配置
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# 飞书多维表格配置
FEISHU_BASE_APP_TOKEN=your_bitable_app_token
FEISHU_NOTES_TABLE_ID=your_notes_table_id
FEISHU_REVIEW_TABLE_ID=your_review_records_table_id

# 飞书机器人 Webhook（可选）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token

# 服务端口
PORT=3000
